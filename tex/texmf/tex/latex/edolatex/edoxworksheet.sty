% edoxworksheet.sty — worksheet settings for EDOX classes
%
% Purpose:
%   Provides environments for worksheets, tests and exams.
%   This package handles:
%     - worksheet titles
%     - page style for worksheets
%     - point display and summaries
%     - exam summaries and grading
%
% Notes:
%   - Worksheets are intended as standalone documents.
%   - Therefore \clearpage is intentionally used to enforce
%     page boundaries between worksheets and summaries.
%
% copyright (c) 2025 Benjamin Benno Falkner
% SPDX-License-Identifier: MIT

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{edoxworksheet}[2026/04/21 Worksheet settings for edox classes]

% ------------------------------------------------------------
% Dependencies
% ------------------------------------------------------------
\RequirePackage{edoxexercise}
\RequirePackage{edoxgrades}

% ------------------------------------------------------------
% Language-dependent labels
% ------------------------------------------------------------
\providecommand{\worksheetname}{\iflanguage{ngerman}{Arbeitsblatt}{Worksheet}}
\providecommand{\testname}{\iflanguage{ngerman}{Test}{Test}}
\providecommand{\examname}{\iflanguage{ngerman}{Klausur}{Exam}}
\providecommand{\totalname}{\iflanguage{ngerman}{Gesamt}{Total}}
\providecommand{\gradename}{\iflanguage{ngerman}{Note}{Grade}}
\providecommand{\wishname}{\iflanguage{ngerman}{Viel Erfolg!}{Good Luck!}}
\providecommand{\solutionname}{\iflanguage{ngerman}{Lösung}{Solution}}

% ------------------------------------------------------------
% Counters
% ------------------------------------------------------------
\providecounter{wspage}
\setcounter{wspage}{1}
\providecounter{worksheet}

% ------------------------------------------------------------
% Name field shown in worksheet header
% If \studentname is defined, it is printed automatically.
% ------------------------------------------------------------
\newcommand*\edo@namefield{%
  Name: \ifcsname studentname\endcsname \studentname\else \underline{\hspace{6cm}}\fi
}

% ------------------------------------------------------------
% Page style for worksheets
%
% Uses LaTeX page counter (\thepage) instead of a manual counter.
% ------------------------------------------------------------
\providepagestyle{edoWorkSheet}{
  (\textwidth,0pt)
  {\rightmark\hfill\edo@namefield}{\edo@namefield\hfill\rightmark}{\edo@namefield\hfill\rightmark}
  (\textwidth,0pt)
}{
  (\textwidth,0pt)
  {\thewspage\hfill\addtocounter{wspage}{1}}{\hfill\thewspage\addtocounter{wspage}{1}}{\hfill\thewspage\addtocounter{wspage}{1}}
  (\textwidth,0pt)
}
