% ------------------------------------------------------------
% Helper commands
% ------------------------------------------------------------
\providecommand{\setpoints}[1]{\setcounter{points}{#1}}
\providecommand{\sign}{}

% ------------------------------------------------------------
% Worksheet title support
% ------------------------------------------------------------

% Date field
\def\@pdate{}
\newcommand\pdate[1]{\def\@pdate{#1}}

% Title layout
\newcommand{\worksheettitle}[2]{%
  \null
  \noindent{\huge \textsc{\textbf{#1}}}\hfill\small{}\\
  {\large {#2}}\hfill{\small \@pdate}\par
  \vspace{3ex}%
}

% ------------------------------------------------------------
% Section style used in exams
% ------------------------------------------------------------
\NewDocumentCommand{\wssection}{o m}{%
  \vspace{1em}
  \IfNoValueTF{#1}
    {\markright{#2}}   
    {\markright{#1}} 
  \noindent{\Large\bfseries #2}%
  \par\vspace{0.5em}
  \@tosolution{\vspace{.6em}\noindent\large\textbf{#2 : }\par\vspace{0.5em}}
}

% ------------------------------------------------------------
% Worksheet initialization helper
%
% Resets counters and enforces a new page.
% The page break is intentional because worksheets are
% treated as standalone units.
% ------------------------------------------------------------
\newcommand{\beginws}{
  \clearpage
  \setcounter{exercise}{0}%
  \setcounter{subexercise}{0}%
  \setcounter{points}{0}%
  \setcounter{subexercisepoints}{0}%
  \setcounter{wspage}{1}%
  \pagestyle{edoWorkSheet}%
}

% ------------------------------------------------------------
% Worksheet environment
% ------------------------------------------------------------
\newenvironment{worksheet}[2][solution]{%
  \edef\ws@savedpagestyle{\currentpagestyle}%
  \beginws
  \stepcounter{worksheet}%
  \worksheettitle{\worksheetname}{#2}%
  \begingroup
  \def\ws@mode{#1}%
  \parindent=0pt
  \let\section\wssection 
}{%
  \clearpage
  \def\ws@nosolution{nosolution}%
  \ifx\ws@mode\ws@nosolution\else
    \printsolutions%
    \clearpage
  \fi
  \endgroup
  \pagestyle{\ws@savedpagestyle}%
}

% ------------------------------------------------------------
% Test environment (shows points)
% ------------------------------------------------------------
\newenvironment{test}[2][solution]{%
  \edef\ws@savedpagestyle{\currentpagestyle}%
  \beginws
  \stepcounter{worksheet}%
  \worksheettitle{\testname}{#2}%
  \begingroup
  \def\ws@mode{#1}%
  \parindent=0pt
  \@points@showtrue
  \let\section\wssection 
}{%
  \clearpage
  \def\ws@nosolution{nosolution}%
  \ifx\ws@mode\ws@nosolution\else
    \printsolutions%
    \clearpage
  \fi
  \endgroup
  \pagestyle{\ws@savedpagestyle}%
}

% ------------------------------------------------------------
% Exam summary helpers
% ------------------------------------------------------------
\providecommand{\examfinal}{
  \vskip1cm
  \textbf{\wishname}\hfill\textbf{\totalname: \thepoints\space\pointsname}
}

\providecommand{\examsummary}[1][]{
  \printsolutions
  \hfill\textbf{\totalname: \underline{\hspace{1cm}}/ \thepoints\space\pointsname}
  
  \gradestable{\c@points}
  
  \vskip 1mm
  \noindent\textbf{\gradename: \underline{\hspace{4cm}}}

  \vskip1cm
  \noindent \underline{\hspace{4cm}}\\
  \noindent #1
}

% ------------------------------------------------------------
% Exam environment
% ------------------------------------------------------------
\newenvironment{exam}[2][solution]{%
  \edef\ws@savedpagestyle{\currentpagestyle}%
  \beginws
  \stepcounter{worksheet}%
  \worksheettitle{\examname}{#2}%
  \begingroup
  \def\ws@mode{#1}%
  \parindent=0pt
  \@points@showtrue
  \let\section\wssection
}{%
  \examfinal
  \clearpage
  \def\ws@nosolution{nosolution}%
  \ifx\ws@mode\ws@nosolution\else
    \examsummary[\sign]
    \clearpage
  \fi
  \endgroup
  \pagestyle{\ws@savedpagestyle}%
}


\newcommand{\answerbox}[2][\textwidth]{%
  \vbox{%
    %\hrule
    \@tempcnta=0
    \loop
      \advance\@tempcnta by 1
      \vskip 1cm
      \hrule width #1
      \ifdim \@tempcnta cm < #2
    \repeat
  }%
}

\newcommand{\mathbox}[2][\textwidth]{%
  \vbox{%
    \@tempcnta=0
    \hrule width #1
    \loop
      \advance\@tempcnta by 1
      \hbox to #1{%
        \cleaders\hbox{\vrule height 0.5cm depth 0pt\hskip 0.5cm}\hfill
        \vrule height 0.5cm depth 0pt
      }%
      \hrule width #1
      \ifdim \@tempcnta\dimexpr 0.5cm\relax < \dimexpr #2-1mm\relax
    \repeat
  }%
}