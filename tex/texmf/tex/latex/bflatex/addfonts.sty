\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{addfonts}

\RequirePackage{amsmath} 
\RequirePackage{amssymb}
\RequirePackage{fontspec}

\newif\ifuseTeXTree
\useTeXTreetrue
\IfFileExists{fontconfig.tex}{
  \input{fontconfig.tex}
}{
  \newcommand{\fontpath}{./texmf/}
}

\newcommand{\fontfolder}[1]{%
  \ifuseTeXTree
    \fontpath fonts/#1/%
  \else
    \fontpath
  \fi
}

\newif\iffiramath

\DeclareOption{inter}{
  \setmainfont{Inter}[
    Path           = \fontfolder{truetype/inter},
    Extension      = .ttf,
    UprightFont    = *-Regular,
    BoldFont       = *-Bold,
    ItalicFont     = *-Italic,
    BoldItalicFont = *-BoldItalic,
  ]
}
\DeclareOption{fira}{
  \setmainfont{FiraSans}[
    Path           = \fontfolder{truetype/firasans},
    Extension      = .ttf,
    UprightFont    = *-Regular,
    BoldFont       = *-Bold,
    ItalicFont     = *-Italic,
    BoldItalicFont = *-BoldItalic,
  ]
}
\DeclareOption{firamath}{
  \firamathtrue
}
\DeclareOption{firafull}{
  \firamathtrue
  \setmainfont{FiraSans}[
    Path           = \fontfolder{truetype/firasans},
    Extension      = .ttf,
    UprightFont    = *-Regular,
    BoldFont       = *-Bold,
    ItalicFont     = *-Italic,
    BoldItalicFont = *-BoldItalic,
  ]
}
\DeclareOption{garamond}{
  \setmainfont{EBGaramond}[
    Path           = \fontfolder{opentype/ebgaramond},
    Extension      = .otf,
    UprightFont    = *-Regular,
    BoldFont       = *-Bold,
    ItalicFont     = *-Italic,
    BoldItalicFont = *-BoldItalic,
  ]
}
\DeclareOption{libertinus}{
  \setmainfont{LibertinusSerif}[
    Path           = \fontfolder{opentype/libertinus},
    Extension      = .otf,
    UprightFont    = *-Regular,
    BoldFont       = *-Bold,
    ItalicFont     = *-Italic,
    BoldItalicFont = *-BoldItalic,
  ]
}
\DeclareOption*{\PackageWarning{addfonts}{Unknown font '\CurrentOption'}}
\ExecuteOptions{fira}
\ProcessOptions\relax

\iffiramath
  \RequirePackage{unicode-math}
  \AtEndOfPackage{%
    \setmathfont{FiraMath-Regular}[
      Path      = \fontfolder{opentype/firamath},
      Extension = .otf,
    ]%
  }
\fi